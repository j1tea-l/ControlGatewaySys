{
  "routes": [
    {
      "prefix": "/dsp1",
      "route_type": "local",
      "driver": {
        "name": "dsp1",
        "host": "10.0.0.3",
        "port": 9000,
        "protocol": "udp",
        "retry": {
          "timeout_sec": 1.0,
          "retries": 2,
          "retry_backoff_sec": 0.2
        }
      }
    }
  ],
  "ntp": {
    "enabled": true,
    "server": "pool.ntp.org",
    "poll_interval_sec": 30.0,
    "timeout_sec": 1.0,
    "alpha": 0.2
  },
  "listen_ip": "0.0.0.0",
  "listen_port": 8000,
  "log_level": "INFO",
  "log_file": "logs/pshu.log",
  "telemetry": {
    "enabled": false,
    "listen_ip": "0.0.0.0",
    "listen_port": 9100,
    "targets": [
      {
        "name": "controller",
        "host": "127.0.0.1",
        "port": 9200
      }
    ]
  }
}
