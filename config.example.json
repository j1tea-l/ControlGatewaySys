{
  "routes": [
    {
      "prefix": "/device/amp/",
      "route_type": "local",
      "driver": {
        "name": "AmpZone1",
        "host": "127.0.0.1",
        "port": 9001,
        "protocol": "udp",
        "retry": {
          "timeout_sec": 1.0,
          "retries": 2,
          "retry_backoff_sec": 0.2
        }
      }
    },
    {
      "prefix": "/serial/projector/",
      "route_type": "ppp",
      "driver": {
        "name": "PPP1",
        "host": "127.0.0.1",
        "port": 9002,
        "protocol": "tcp",
        "retry": {
          "timeout_sec": 1.0,
          "retries": 3,
          "retry_backoff_sec": 0.3
        }
      }
    }
  ],
  "ntp": {
    "enabled": true,
    "server": "pool.ntp.org",
    "poll_interval_sec": 30.0,
    "timeout_sec": 1.0,
    "alpha": 0.2
  }
}